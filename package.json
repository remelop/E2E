{
  "name": "AppRegistroRoles",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:unit": "jest __tests__/unit",
    "test:integration": "jest __tests__/integration",
    "test:e2e": "detox test -c android.emu.debug",
    "test:e2e:build": "detox build -c android.emu.debug",
    "test:e2e:web": "cypress open",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit:watch": "jest __tests__/unit --watch"
  },
  "dependencies": {
    "@expo/webpack-config": "^18.0.1",
    "@react-native-async-storage/async-storage": "1.18.2",
    "@react-native-picker/picker": "2.4.10",
    "@react-navigation/native": "6.1.7",
    "@react-navigation/native-stack": "6.9.13",
    "@react-navigation/stack": "^6.3.17",
    "axios": "^1.6.0",
    "expo": "49.0.0",
    "expo-camera": "~13.4.4",
    "expo-document-picker": "~11.5.4",
    "expo-file-system": "~15.4.5",
    "expo-location": "~16.1.0",
    "expo-media-library": "~15.4.1",
    "expo-secure-store": "~12.3.1",
    "expo-splash-screen": "^0.18.2",
    "expo-status-bar": "1.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.6",
    "react-native-gesture-handler": "^2.12.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "^3.21.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "0.19.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/user-event": "^14.6.1",
    "cypress": "^15.12.0",
    "detox": "^20.47.0",
    "detox-expo-helpers": "^0.6.0",
    "jest": "^29.7.0",
    "jest-expo": "^49.0.0",
    "jest-expo-enzyme": "^1.5.0"
  },
  "detox": {
    "testRunner": "jest",
    "runnerConfig": "e2e/jest.config.js",
    "configurations": {
      "android.emu.debug": {
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && gradle assembleDebug assembleAndroidTest -DtestBuildType=debug && cd ..",
        "type": "android.emulator",
        "name": "Pixel_5",
        "device": {
          "avdName": "Pixel_5"
        }
      }
    }
  }
}